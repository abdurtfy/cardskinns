# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# The exact tab name inside your spreadsheet (default: Payments)
GOOGLE_SHEET_NAME=Payments

# Path to the service account JSON file you downloaded from Google Cloud
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Your Razorpay webhook secret (Dashboard → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── SMTP (Email) ──────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Your sending Gmail address
SMTP_USER=you@gmail.com
# Gmail App Password (NOT your regular password)
# https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_16_char_app_password

# ── eBook ─────────────────────────────────────────────────────────────────────
# The Google Drive (or any public) link to your eBook
EBOOK_DRIVE_LINK=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing

# Email subject line
EMAIL_SUBJECT=Your eBook is here! 📚

# Email body — use {name} and {link} as placeholders
EMAIL_BODY_TEMPLATE=Hi {name},\n\nThank you for your purchase!\n\nHere is your eBook:\n{link}\n\nHappy reading!

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
